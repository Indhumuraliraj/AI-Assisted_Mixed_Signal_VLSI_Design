library(AMUX2_3V) {

/* unit attributes */
time_unit                : "1ns";
voltage_unit             : "1V";
current_unit             : "1uA";
pulling_resistance_unit  : "1kohm";
leakage_power_unit       : "1nW";
capacitive_load_unit(1,pf);

/* timing thresholds required by OpenSTA */
slew_lower_threshold_pct_rise : 20;
slew_upper_threshold_pct_rise : 80;
slew_lower_threshold_pct_fall : 20;
slew_upper_threshold_pct_fall : 80;
input_threshold_pct_rise      : 50;
input_threshold_pct_fall      : 50;
output_threshold_pct_rise     : 50;
output_threshold_pct_fall     : 50;
slew_derate_from_library      : 1;

cell(AMUX2_3V) {

  pin(VDD) {
    direction      : input ;
    max_transition : 2.5;
    capacitance    : 0.001;
  }

  pin(VSS) {
    direction      : input ;
    max_transition : 2.5;
    capacitance    : 0.001;
  }

  pin(I0) {
    direction      : input ;
    max_transition : 2.5;
    capacitance    : 0.001;
  }

  pin(I1) {
    direction      : input ;
    max_transition : 2.5;
    capacitance    : 0.001;
  }

  pin(out) {
    direction   : output ;
    capacitance : 0.001;
  }

  pin(select) {
    direction      : input ;
    max_transition : 2.5;
    capacitance    : 0.001;
  }
}
}

